# .env.example — copy to .env and fill in your values

# ── OpenRouter ────────────────────────────────────────────────────────────────
OPENROUTER_API_KEY=sk-or       # from openrouter.ai → Keys

# Model to use — pick any free model from openrouter.ai/models
# Free options:
#   meta-llama/llama-3-70b-instruct:nitro   ← best quality, free
#   mistralai/mistral-7b-instruct:free      ← faster, free
#   google/gemma-7b-it:free                 ← alternative free
OPENROUTER_MODEL=meta-llama/llama-3-70b-instruct:nitro

# ── Slack ─────────────────────────────────────────────────────────────────────
SLACK_BOT_TOKEN=
SLACK_SIGNING_SECRET=...
SLACK_CHANNEL_ID=C0XXXXXXXXX

# ── AWS ───────────────────────────────────────────────────────────────────────
AWS_ACCESS_KEY_ID=...
AWS_SECRET_ACCESS_KEY=...
AWS_REGION=us-east-1
EC2_INSTANCE_ID=i-0xxxxxxxxxxxxxxxxx

# ── Bot config ────────────────────────────────────────────────────────────────
POLL_INTERVAL_SECONDS=60
CPU_THRESHOLD=80
LOG_LEVEL=INFO
